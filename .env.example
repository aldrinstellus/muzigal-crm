# Muzigal CRM Environment Variables
# Copy to .env.local and fill in values

# Google Apps Script Web App URL (the deployed exec URL)
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Webhook secret (must match Config tab in Google Sheet)
VITE_WEBHOOK_SECRET=your-webhook-secret

# Google OAuth Client ID (for login)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
