{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "paths": {
      "@zoo/design-tokens": ["../design-tokens/index.css"],
      "@zoo/design-tokens/*": ["../design-tokens/*"]
    }
  },
  "include": ["src"]
}
